# =========================================================================
# 1. Python Environment (가상환경 및 실행 관련)
# =========================================================================
# 네가 생성한 가상환경 폴더명 (idpass)
idpass/

# 일반적인 가상환경 폴더명들 (혹시 모를 대비)
venv/
env/
ENV/

# 파이썬 실행 시 생성되는 캐시 파일
__pycache__/
*.py[cod]
*$py.class

# =========================================================================
# 2. AI & Data (AI 모델 및 업로드 파일)
# =========================================================================
# Java 서버에서 넘어온 테스트용 신분증 이미지들 (보안)
uploads/
*.jpg
*.jpeg
*.png

# EasyOCR 등 AI 모델이 다운로드되는 임시 폴더
.easyocr/

# =========================================================================
# 3. OS & IDE (운영체제 및 에디터 설정)
# =========================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/

# =========================================================================
# 4. Distribution (배포 관련 제외)
# =========================================================================
# 빌드 결과물이나 배포용 패키지
dist/
build/
*.egg-info/